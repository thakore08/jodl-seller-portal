# Server
PORT=5000
NODE_ENV=development

# ─── Zoho Books ──────────────────────────────────────────────────────────────
ZOHO_ORG_ID=60032173740
ZOHO_CLIENT_ID=1000.X4A1L3LY97NT3YUQVOWTOUQ2RDBOYX&
ZOHO_CLIENT_SECRET=206a42031553274fcae41f76a1b1b87ac8bdcf6ca1&
ZOHO_REFRESH_TOKEN=1000.60f24c93eb8de095f791e47b85173787.2076eded4043568a8ee966d2d6336605&

# Zoho API base for QA / Sandbox
ZOHO_API_BASE=https://sandbox.zohoapis.com/books/v3

# Zoho OAuth token endpoint (use region-specific if needed)
# US:  https://accounts.zoho.com/oauth/v2/token
# IN:  https://accounts.zoho.in/oauth/v2/token
# EU:  https://accounts.zoho.eu/oauth/v2/token
ZOHO_AUTH_URL=https://accounts.zoho.com/oauth/v2/token

# How often (in minutes) the background scheduler proactively refreshes the
# Zoho access token. Zoho tokens expire in 60 min; default 50 min gives a
# comfortable buffer. Decrease for extra safety, increase to reduce API calls.
ZOHO_TOKEN_REFRESH_INTERVAL_MINS=50

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=8h

# ─── WhatsApp Business (Meta Cloud API) ──────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_API_VERSION=v19.0

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
