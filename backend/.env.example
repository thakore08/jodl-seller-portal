# Backend environment example for Docker/local
PORT=5000
FRONTEND_URL=http://localhost:8080
UPLOAD_DIR=./uploads

# JWT
JWT_SECRET=dev_secret
JWT_EXPIRES_IN=8h

# Zoho Books (replace with real sandbox/prod tokens)
ZOHO_ORG_ID=60032173740
ZOHO_CLIENT_ID=YOUR_CLIENT_ID
ZOHO_CLIENT_SECRET=YOUR_CLIENT_SECRET
ZOHO_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
ZOHO_AUTH_URL=https://accounts.zoho.in/oauth/v2/token
ZOHO_API_BASE=https://sandbox.zohoapis.com/books/v3

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="JODL Portal <noreply@jodl.com>"

# WhatsApp (optional)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# OCR tuning
ENABLE_OCR=true
FORCE_OCR=false
OCR_LANGS=eng
OCR_MAX_PAGES=2
OCR_IMAGE_DPI=200

# File upload limit (MB)
MAX_FILE_SIZE_MB=10
